# Database (Neon.tech PostgreSQL)
DATABASE_URI=postgresql://user:password@host:5432/cloud_travel_solution

# Payload CMS
PAYLOAD_SECRET=your-payload-secret-key-min-32-chars-here

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CloudTravelSolution
# Canonical server URL used by Payload CMS (serverURL in payload.config.ts).
# Optional — falls back to NEXT_PUBLIC_SITE_URL when unset. In production set to your https origin.
SERVER_URL=http://localhost:3000

# Email (Resend)
# Resend dashboard -> API Keys. Live sending key (starts with re_). Leave as placeholder to disable email.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@cloudtravelsolution.com
TEAM_NOTIFICATION_EMAIL=info@cloudtravelsolution.com
# Resend dashboard -> Webhooks -> (your webhook) -> Signing secret. Verifies inbound
# email-event payloads at /api/email/webhook. While unset, signature checks are skipped (soft rollout).
RESEND_WEBHOOK_SECRET=
# Secret that authorizes the campaign cron endpoint (POST /api/email/cron).
# Generate a long random string (e.g. `openssl rand -hex 32`); send it as the `x-cron-secret` header.
CRON_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Analytics
# Google Analytics 4 measurement ID. Google Analytics -> Admin -> Data Streams -> (stream) -> Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Tag Manager container ID. GTM workspace -> Admin -> Container settings -> Container ID.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp (Interakt)
INTERAKT_API_KEY=
INTERAKT_WEBHOOK_SECRET=

# Razorpay (Phase 2)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Zoho CRM (Phase 2)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Cloudflare Turnstile (bot protection for /api/track)
# Both keys must be set to enable verification; while unset, /api/track falls back
# to rate-limit-only behavior. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
